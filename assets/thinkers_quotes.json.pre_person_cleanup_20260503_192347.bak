    "author_type": "philosopher",
    "text_de": "Gerechte Politik muss die realen Faehigkeiten von Menschen entwickeln, nicht nur formale Rechte zaehlen.",
    "source": "Creating Capabilities",
    "year": 2011
  },
  {
    "id": "philosopher_bulk_10",
    "author": "Juergen Habermas",
    "author_type": "philosopher",
    "text_de": "Legitime Ordnung braucht oeffentliche Vernunft und argumentativen Streit statt blosser Autoritaet.",
    "source": "Faktizitaet und Geltung",
    "year": 1992
  },
  {
    "id": "politician_bulk_01",
    "author": "Nelson Mandela",
    "author_type": "politician",
    "text_de": "Versoehnung verlangt Gerechtigkeit, aber auch den Mut, Institutionen gemeinsam neu aufzubauen.",
    "source": "Long Walk to Freedom",
    "year": 1994
  },
  {
    "id": "politician_bulk_02",
    "author": "Willy Brandt",
    "author_type": "politician",
    "text_de": "Demokratische Reform gelingt, wenn soziale Sicherheit und Freiheit zusammen gedacht werden.",
    "source": "Regierungserklaerungen",
    "year": 1970
  },
  {
    "id": "politician_bulk_03",
    "author": "Angela Davis",
    "author_type": "politician",
    "text_de": "Sicherheit ohne soziale Rechte produziert neue Ungleichheit statt nachhaltiger Ordnung.",
    "source": "Freedom Is a Constant Struggle",
    "year": 2016
  },
  {
    "id": "politician_bulk_04",
    "author": "Franklin D. Roosevelt",
    "author_type": "politician",
    "text_de": "Politik muss Krisen durch Arbeit, Solidaritaet und handlungsfaehige Institutionen beantworten.",
    "source": "Fireside Chats",
    "year": 1933
  },
  {
    "id": "politician_bulk_05",
    "author": "Salvador Allende",
    "author_type": "politician",
    "text_de": "Demokratische Transformation braucht Beteiligung der Vielen und Kontrolle wirtschaftlicher Macht.",
    "source": "Rede vor den Vereinten Nationen",
    "year": 1972
  },
  {
    "id": "politician_bulk_06",
    "author": "Jawaharlal Nehru",
    "author_type": "politician",
    "text_de": "Entwicklung verbindet wissenschaftlichen Fortschritt mit pluraler Kultur und sozialer Gerechtigkeit.",
    "source": "The Discovery of India",
    "year": 1946
  },
  {
    "id": "politician_bulk_07",
    "author": "Olof Palme",
    "author_type": "politician",
    "text_de": "Ein starker Sozialstaat schuetzt Freiheit, weil er reale Chancen statt blosser Versprechen schafft.",
    "source": "Parlamentsreden",
    "year": 1974
  },
  {
    "id": "politician_bulk_08",
    "author": "Thomas Sankara",
    "author_type": "politician",
    "text_de": "Politische Unabhaengigkeit bleibt leer, wenn wirtschaftliche Abhaengigkeit fortbesteht.",
    "source": "Rede in Addis Abeba",
    "year": 1987
  },
  {
    "id": "politician_bulk_09",
    "author": "Claudia Jones",
    "author_type": "politician",
    "text_de": "Antirassistische und soziale Politik gehoeren zusammen, wenn Demokratie wirklich inklusiv sein soll.",
    "source": "Political Writings",
    "year": 1955
  },
  {
    "id": "politician_bulk_10",
    "author": "Lech Walesa",
    "author_type": "politician",
    "text_de": "Gewerkschaftliche Organisation kann Freiheitsrechte mit Wuerde in der Arbeit verbinden.",
    "source": "Reden zur Solidarność-Bewegung",
    "year": 1981
  }
]