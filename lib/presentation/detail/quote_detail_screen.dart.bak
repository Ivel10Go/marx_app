import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:google_fonts/google_fonts.dart';

import '../../core/utils/share_card_renderer.dart';
import '../../data/models/quote.dart';
import '../../domain/providers/daily_quote_provider.dart';
import '../../domain/providers/favorites_provider.dart';
import '../../domain/providers/repository_providers.dart';
import '../../widgets/app_decorated_scaffold.dart';
import '../../widgets/category_chip.dart';

class QuoteDetailScreen extends ConsumerWidget {
  const QuoteDetailScreen({required this.quoteId, super.key});

  final String quoteId;

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final scheme = Theme.of(context).colorScheme;
    final quoteAsync = ref.watch(quoteByIdProvider(quoteId));
    final favoriteAsync = ref.watch(isFavoriteProvider(quoteId));

    return AppDecoratedScaffold(
      appBar: AppBar(
        title: const Text('Detail'),
        actions: <Widget>[
          favoriteAsync.when(
            data: (isFavorite) {
              return IconButton.filledTonal(
                onPressed: () async {
                  final repo = ref.read(quoteRepositoryProvider);
                  if (isFavorite) {
                    await repo.removeFavorite(quoteId);
                  } else {
                    await repo.addFavorite(quoteId);
                  }
                },
                icon: Icon(
                  isFavorite
                      ? Icons.favorite_rounded
                      : Icons.favorite_border_rounded,
                ),
              );
            },
            loading: () => const SizedBox.shrink(),
            error: (_, __) => const SizedBox.shrink(),
          ),
        ],
      ),
      bottomNavigationBar: quoteAsync.when(
        data: (quote) {
          if (quote == null) {
            return const SizedBox.shrink();
          }

          return SafeArea(
            minimum: const EdgeInsets.fromLTRB(24, 0, 24, 16),
            child: Row(
              children: <Widget>[
                Expanded(
                  child: OutlinedButton.icon(
                    onPressed: () async {
                      await ShareCardRenderer().shareQuote(quote, context);
                    },
                    icon: const Icon(Icons.share_outlined),
                    label: const Text('Teilen'),
                  ),
                ),
                const SizedBox(width: 12),
                Expanded(
                  child: FilledButton.icon(
                    onPressed: () => _showSimpleExplanation(context, quote),
                    icon: const Icon(Icons.auto_awesome_rounded),
                    label: const Text('Einfacher erklaeren'),
                  ),
                ),
              ],
            ),
          );
        },
        loading: () => const SizedBox.shrink(),
        error: (_, __) => const SizedBox.shrink(),
      ),
      child: quoteAsync.when(
        data: (quote) {
          if (quote == null) {
            return const Center(child: Text('Zitat nicht gefunden.'));
          }

          return ListView(
            padding: const EdgeInsets.fromLTRB(24, 10, 24, 96),
            children: <Widget>[
              const EditorialSectionTitle(
                label: 'Textstelle',
                title: 'Detail und Kontext',
              ),
              const SizedBox(height: 16),
              Container(
                padding: const EdgeInsets.all(20),
                decoration: BoxDecoration(
                  color: scheme.surfaceContainerHighest,
                  borderRadius: BorderRadius.circular(16),
                  border: Border.all(
                    color: scheme.outline.withValues(alpha: 0.5),
                  ),
                ),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: <Widget>[
                    Text(
                      '${quote.source} · ${quote.year}',
                      style: GoogleFonts.lora(
                        fontSize: 11,
                        fontStyle: FontStyle.italic,
                        letterSpacing: 0.4,
                        color: scheme.onSurface.withValues(alpha: 0.55),
                      ),
                    ),
                    const SizedBox(height: 12),
                    Text(
                      quote.textDe,
                      style: Theme.of(context).textTheme.displayLarge,
                    ),
                    const SizedBox(height: 14),
                    Divider(
                      color: scheme.primary.withValues(alpha: 0.25),
                      height: 1,
                    ),
                    const SizedBox(height: 12),
                    Row(
                      children: <Widget>[
                        Expanded(child: Text('${quote.source}, ${quote.year}')),
                      ],
                    ),
                    const SizedBox(height: 12),
                    Wrap(
                      spacing: 6,
                      runSpacing: 6,
                      children: quote.category
                          .map((String item) => CategoryChip(label: item))
                          .toList(),
                    ),
                  ],
                ),
              ),
              const SizedBox(height: 12),
              _SectionCard(
                title: 'Kurzerklaerung',
                body: quote.explanationShort,
              ),
              const SizedBox(height: 16),
              _SectionCard(
                title: 'Ausfuehrliche Erklaerung',
                body: quote.explanationLong,
              ),
              if (quote.funFact != null) ...<Widget>[
                const SizedBox(height: 16),
                _SectionCard(title: 'Kontext', body: quote.funFact!),
              ],
              const SizedBox(height: 16),
              _SectionCard(
                title: 'Verwandte Zitate',
                body: quote.relatedIds.isEmpty
                    ? 'Keine verwandten Zitate hinterlegt.'
                    : quote.relatedIds.join(' · '),
              ),
            ],
          );
        },
        loading: () => const Center(child: CircularProgressIndicator()),
        error: (error, _) => Center(child: Text('Fehler: $error')),
      ),
    );
  }
}

void _showSimpleExplanation(BuildContext context, Quote quote) {
  final scheme = Theme.of(context).colorScheme;
  showModalBottomSheet<void>(
    context: context,
    isScrollControlled: true,
    backgroundColor: scheme.surfaceContainerHighest,
    shape: const RoundedRectangleBorder(
      borderRadius: BorderRadius.vertical(top: Radius.circular(20)),
    ),
    builder: (context) {
      return Padding(
        padding: const EdgeInsets.fromLTRB(24, 20, 24, 24),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          crossAxisAlignment: CrossAxisAlignment.start,
          children: <Widget>[
            Text(
              'EINFACHER ERKLAERT',
              style: GoogleFonts.inter(
                fontSize: 10,
                fontWeight: FontWeight.w500,
                letterSpacing: 1.2,
                color: scheme.onSurface.withValues(alpha: 0.55),
              ),
            ),
            const SizedBox(height: 12),
            Text(
              _simpleExplanationFor(quote),
              style: Theme.of(context).textTheme.bodyLarge,
            ),
          ],
        ),
      );
    },
  );
}

String _simpleExplanationFor(Quote quote) {
  final source = quote.source;
  return 'Kurz gesagt: ${quote.explanationShort} '
      'Dieses Zitat aus $source zeigt den Kern des Arguments in direkter Sprache.';
}

class _SectionCard extends StatelessWidget {
  const _SectionCard({required this.title, required this.body});

  final String title;
  final String body;

  @override
  Widget build(BuildContext context) {
    final scheme = Theme.of(context).colorScheme;

    return Container(
      padding: const EdgeInsets.all(18),
      decoration: BoxDecoration(
        color: scheme.surface,
        borderRadius: BorderRadius.circular(14),
        border: Border.all(
          color: scheme.outline.withValues(alpha: 0.5),
          width: 0.5,
        ),
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: <Widget>[
          Text(
            title,
            style: Theme.of(
              context,
            ).textTheme.titleMedium?.copyWith(fontWeight: FontWeight.w700),
          ),
          const SizedBox(height: 6),
          Divider(color: scheme.primary.withValues(alpha: 0.22), height: 1),
          const SizedBox(height: 8),
          Text(body, style: Theme.of(context).textTheme.bodyMedium),
        ],
      ),
    );
  }
}
