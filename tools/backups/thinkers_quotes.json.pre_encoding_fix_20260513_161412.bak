  {
    "id": "fundiert_001",
    "text_de": "Ein Gespenst geht um in Europa - das Gespenst des Kommunismus.",
    "text_original": "Ein Gespenst geht um in Europa - das Gespenst des Kommunismus.",
    "source": "Manifest der Kommunistischen Partei",
    "year": 1848,
    "chapter": "Vorwort",
    "category": [
      "Klassenkampf",
      "Politik"
    ],
    "difficulty": "beginner",
    "series": "fundiert",
    "explanation_short": "Die berühmte Eröffnung des Manifests beschreibt die politische Furcht der alten Ordnung.",
    "explanation_long": "Marx und Engels nutzen die Metapher des Gespensts, um die europaweite Wirkung der kommunistischen Bewegung zu zeigen. Das Bild verweist auf die Angst der herrschenden Klassen vor organisierter Arbeiterpolitik.",
    "related_ids": [],
    "fun_fact": "Eine der bekanntesten politischen Auftaktzeilen des 19. Jahrhunderts.",
    "author": "Karl Marx & Friedrich Engels",
    "author_type": "philosopher"
  },
  {
    "id": "fundiert_002",
    "text_de": "Die Geschichte aller bisherigen Gesellschaft ist die Geschichte von Klassenkämpfen.",
    "text_original": "Die Geschichte aller bisherigen Gesellschaft ist die Geschichte von Klassenkämpfen.",
    "source": "Manifest der Kommunistischen Partei",
    "year": 1848,
    "chapter": "Bourgeois und Proletarier",
    "category": [
      "Geschichte",
      "Klassenkampf"
    ],
    "difficulty": "beginner",
    "series": "fundiert",
    "explanation_short": "Kernthese des historischen Materialismus im Manifest.",
    "explanation_long": "Die Formel fasst Marx' Geschichtsdeutung zusammen: soziale Entwicklung wird durch Konflikte zwischen Klassen bestimmt, nicht durch Ideen allein.",
    "related_ids": [],
    "fun_fact": "Dieser Satz prägt bis heute viele Debatten über soziale Ungleichheit.",
    "author": "Karl Marx & Friedrich Engels",
    "author_type": "philosopher"
  },
  {
    "id": "fundiert_003",
    "text_de": "Proletarier aller Länder, vereinigt Euch!",
    "text_original": "Proletarier aller Länder, vereinigt Euch!",
    "source": "Manifest der Kommunistischen Partei",
    "year": 1848,
    "chapter": "Schluss",
    "category": [
      "Internationalismus",
      "Bewegung"
    ],
    "difficulty": "beginner",
    "series": "fundiert",
    "explanation_short": "Der programmatische Schlussappell des Manifests.",
    "explanation_long": "Der Satz fordert grenzübergreifende Solidarität der Arbeiterklasse. Marx und Engels setzen damit auf internationale Organisation statt nationaler Vereinzelung.",
    "related_ids": [],
    "fun_fact": "Der Aufruf wurde zum Leitspruch vieler Arbeiterorganisationen weltweit.",
    "author": "Karl Marx & Friedrich Engels",
    "author_type": "philosopher"
  },
  {
    "id": "fundiert_004",
    "text_de": "Die Theorie der Kommunisten kann in dem einen Ausdruck zusammengefasst werden: Aufhebung des Privateigentums.",
    "text_original": "Die Theorie der Kommunisten kann in dem einen Ausdruck zusammengefasst werden: Aufhebung des Privateigentums.",
    "source": "Manifest der Kommunistischen Partei",
    "year": 1848,
    "chapter": "Proletarier und Kommunisten",
    "category": [
      "Eigentum",
      "Theorie"
    ],
    "difficulty": "intermediate",
    "series": "fundiert",
    "explanation_short": "Marx und Engels verdichten das kommunistische Programm auf die Eigentumsfrage.",
    "explanation_long": "Der Satz markiert den zentralen Unterschied zur bürgerlichen Gesellschaft: nicht individülles Gebrauchseigentum, sondern kapitalistisches Privateigentum an Produktionsmitteln steht zur Kritik.",
    "related_ids": [],
    "fun_fact": "Die Passage ist eine der meistdiskutierten Stellen des Manifests.",
    "author": "Karl Marx & Friedrich Engels",
    "author_type": "philosopher"
  },
  {
    "id": "burke_001__2",
    "text_de": "Ein Staat ohne Mittel zur Veränderung hat auch keine Mittel zu seinem Erhalt.",
    "text_original": "A state without the means of some change is without the means of its conservation.",
    "source": "Reflections on the Revolution in France",
    "year": 1790,
    "chapter": "Reflections",
    "category": [
      "Staat",
      "Wandel"
    ],
    "difficulty": "intermediate",
    "series": "burke",
    "explanation_short": "Kurz erklärt: Ein Staat braucht kontrollierte Veränderung, um sich selbst zu erhalten.",
    "explanation_long": "Burke verbindet politische Stabilität mit begrenzter Veränderungsfähigkeit. Der Satz ist zentral, weil er Reform nicht als Gegenspieler von Ordnung darstellt, sondern als Bedingung ihrer Dauer.",
    "related_ids": [],
    "fun_fact": "V1-Ergänzung für den Themenkorpus.",
    "author": "Edmund Burke",
    "author_type": "politician"
  },
  {
    "id": "burke_002",
    "text_de": "Bestand hat Zukunft, wenn Tradition geprüft und behutsam weiterentwickelt wird.",
    "text_original": "Continuity has a future when tradition is examined and carefully developed.",
    "source": "Reflections on the Revolution in France",
    "year": 1790,
    "chapter": "Tradition and Prudence",
    "category": [
      "Tradition",
      "Ordnung",
      "Kontinuität"
    ],
    "difficulty": "intermediate",
    "series": "burke",
    "explanation_short": "Kurz erklärt: Konservative Politik verbindet Wandel mit Kontinuität.",
    "explanation_long": "Das Zitat adressiert zentrale konservative Marker wie Ordnung, Tradition und Kontinuität und erhöht damit die Passung für konservative Profile.",
    "related_ids": [
